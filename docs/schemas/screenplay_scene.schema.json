{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgotten-tides.com/schemas/screenplay_scene.schema.json",
  "title": "Screenplay Scene Schema",
  "description": "Schema for screenplay formatted scenes and beat-level metadata.",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "work_id": { "type": "string" },
    "slug": { "type": "string", "description": "Slug or scene header" },
    "scene_heading": { "type": "string" },
    "pov": { "type": "string" },
    "summary": { "type": "string" },
    "location": { "type": "string" },
    "time_of_day": { "type": "string" },
    "beats": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "intent": { "type": "string" },
          "stakes": { "type": "string" },
          "note": { "type": "string" }
        },
        "required": ["id"],
        "additionalProperties": true
      }
    },
    "stakes": { "$ref": "https://forgotten-tides.com/schemas/scene.schema.json#/properties/stakes" },
    "moral_actions": { "$ref": "https://forgotten-tides.com/schemas/scene.schema.json#/properties/moral_actions" },
    "promise_links": { "$ref": "https://forgotten-tides.com/schemas/scene.schema.json#/properties/promise_links" },
    "knowledge_delta": { "$ref": "https://forgotten-tides.com/schemas/scene.schema.json#/properties/knowledge_delta" },
    "metadata": {
      "type": "object",
      "properties": {
        "schema_version": { "type": "string" },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
