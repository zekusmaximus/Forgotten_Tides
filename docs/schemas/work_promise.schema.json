{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgotten-tides.com/schemas/work_promise.schema.json",
  "title": "Work Promise Schema",
  "description": "Promise/payoff tracking per work.",
  "type": "object",
  "required": ["work_id", "promises"],
  "properties": {
    "work_id": { "type": "string" },
    "promises": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "setup_scene": { "type": "string" },
          "payoff_scene": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "paid", "dropped"] }
        },
        "required": ["id"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
