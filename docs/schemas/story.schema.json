{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgotten-tides.com/schemas/story.schema.json",
  "title": "Story Schema",
  "description": "Schema for stories in The Forgotten Tides universe",
  "type": "object",
  "required": ["id", "type", "summary_50", "summary_200", "cross_refs", "references"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^story-\\d{4}$",
      "description": "Story ID in format story-####"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v?\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version for this frontmatter"
    },
    "uuid": {
      "type": "string",
      "format": "uuid",
      "description": "Optional UUID for unique identification"
    },
    "type": {
      "type": "string",
      "enum": ["story"],
      "description": "Entity type"
    },
    "title": {
      "type": "string",
      "description": "Story title"
    },
    "status": {
      "type": "string",
      "enum": ["canonical", "speculative", "deprecated", "draft"],
      "description": "Canonical status of the story"
    },
    "canon_tier": {
      "type": "string",
      "enum": ["primary_canon", "working_canon", "draft", "speculative", "sandbox", "test", "deprecated"],
      "description": "Retrieval authority tier used by canon indexes and prompt packs"
    },
    "retrieval_role": {
      "type": "string",
      "description": "Optional human-readable retrieval role such as authoritative, working_reference, active_draft, or test_fixture"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional tags for grouping or filtering"
    },
    "story_type": {
      "type": "string",
      "enum": ["short-story", "novel", "novella", "scene", "fragment"],
      "description": "Type of story"
    },
    "summary_50": {
      "type": "string",
      "maxLength": 220,
      "description": "Brief summary (≤ 220 characters)"
    },
    "summary_200": {
      "type": "string",
      "maxLength": 1200,
      "description": "Detailed summary (≤ 1200 characters)"
    },
    "cross_refs": {
      "type": "object",
      "description": "Cross-references to other entities",
      "properties": {
        "characters": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^char-\\d{4}$"
          }
        },
        "locations": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^loc-\\d{4}$"
          }
        },
        "factions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^fact-\\d{4}$"
          }
        },
        "mechanics": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^mech-\\d{4}$"
          }
        },
        "stories": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^story-\\d{4}$"
          }
        }
      },
      "additionalProperties": false
    },
    "references": {
      "type": "object",
      "description": "Canonical references to other entities",
      "properties": {
        "characters": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^char-\\d{4}$"
          }
        },
        "locations": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^loc-\\d{4}$"
          }
        },
        "factions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^fact-\\d{4}$"
          }
        },
        "mechanics": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^mech-\\d{4}$"
          }
        },
        "stories": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^story-\\d{4}$"
          }
        }
      },
      "additionalProperties": false
    },
    "timeline": {
      "type": "object",
      "properties": {
        "setting": {
          "type": "string",
          "description": "When and where the story takes place"
        },
        "duration": {
          "type": "string",
          "description": "Duration of the story events"
        },
        "chronology": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "event": {
                "type": "string"
              },
              "timestamp": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "events": {
      "type": "array",
      "description": "Structured event metadata for timeline validation",
      "items": {
        "type": "object",
        "required": ["id", "timestamp", "summary"],
        "properties": {
          "id": { "type": "string" },
          "timestamp": { "type": "string" },
          "summary": { "type": "string" },
          "canon_tier": {
            "type": "string",
            "enum": ["primary_canon", "working_canon", "draft", "speculative", "sandbox", "test", "deprecated"]
          },
          "causal_note": { "type": "string" },
          "involved_entities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "source": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["memory-as-cost", "identity-erosion", "sacrifice", "conceptual-fragility", "quiet-heroism", "memory-preservation", "institutional-burden", "ethical-forgetting", "inheritance", "duty-vs-faith"]
      }
    },
    "continuity_notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Important continuity notes for this story"
    },
    "bible_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Explicit citations to locked canon documents (e.g. bible/ARCHIVISTS_WAKE_STORY_BIBLE.md or red-line references). Required when the story touches locked elements (Rell, Sutira, Estavan, Tari, Heliodrome, Lattice Gap, zero-anchoring, eddy tracking, etc.). See redline_citation_linter.js and AGENT.md."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "modified": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["canonical", "speculative", "deprecated", "draft"]
        },
        "word_count": {
          "type": "integer",
          "minimum": 0
        },
        "author": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": false
}
